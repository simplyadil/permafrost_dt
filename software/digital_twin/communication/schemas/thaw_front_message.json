{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ThawFrontMessage",
  "description": "Reconstructed thaw front metrics and geometry.",
  "type": "object",
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "time_hours": { "type": "number" },
    "radius_max_m": { "type": ["number", "null"] },
    "radius_avg_m": { "type": ["number", "null"] },
    "points": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "x_m": { "type": "number" },
          "z_m": { "type": "number" }
        },
        "required": ["x_m", "z_m"],
        "additionalProperties": false
      }
    }
  },
  "required": ["time_hours", "radius_max_m", "radius_avg_m", "points"],
  "additionalProperties": false
}
