{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PermafrostSensorMessage2D",
  "description": "Schema for 2D sensor data message representing a single timestep.",
  "type": "object",
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of the reading (optional if using time_hours only)"
    },
    "time_hours": {
      "type": "number",
      "description": "Elapsed time since start of measurement in hours"
    },
    "sensors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sensor_id": { "type": "string" },
          "x_m": { "type": "number" },
          "y_m": { "type": ["number", "null"] },
          "z_m": { "type": "number" },
          "temperature": { "type": "number" }
        },
        "required": ["sensor_id", "x_m", "z_m", "temperature"],
        "additionalProperties": false
      }
    }
  },
  "required": ["time_hours", "sensors"],
  "additionalProperties": false
}
